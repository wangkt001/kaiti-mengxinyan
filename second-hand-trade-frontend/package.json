{
  "name": "second-hand-trade-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vue-cli-service serve",
    "build": "vue-cli-service build --no-eslint",
    "lint": "vue-cli-service lint"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "core-js": "^3.8.3",
    "element-plus": "^2.13.4",
    "pinia": "^3.0.4",
    "vue": "^3.2.13",
    "vue-router": "4"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-typescript": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "typescript": "~5.3.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "rules": {
      "no-undef": "off",
      "vue/valid-v-for": "off",
      "vue/valid-template-root": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
